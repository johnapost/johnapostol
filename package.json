    "@types/react-dom": "19",
    "@types/styled-jsx": "2.2.9",
    "@typescript-eslint/eslint-plugin": "6",
    "@typescript-eslint/parser": "6",
    "cypress": "4.12.1",
    "cypress-dotenv": "1.2.3",
    "dotenv": "8.6.0",
    "eslint": "8.3.0",
