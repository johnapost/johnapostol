{
  "root": true,
  "parser": "@typescript-eslint/parser",
  "extends": [
    "plugin:react/recommended",
    "plugin:@typescript-eslint/recommended",
    "plugin:prettier/recommended"
  ],
  "settings": {
    "react": {
      "version": "detect"
    }
  },
  "rules": {
    "react/no-unknown-property": ["error", { "ignore": ["jsx"] }]
  },
  "ignorePatterns": [
    "cypress/plugins",
    "cypress/support"
  ]
}
